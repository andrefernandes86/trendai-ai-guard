# Local-development environment variables for running the Lambda code
# directly (outside Lambda). Copy to .env and fill in real values.
# Never commit .env to git.

AI_GUARD_API_KEY=your-trend-micro-vision-one-api-key
AI_GUARD_ENDPOINT=https://api.xdr.trendmicro.com/v3.0/aiSecurity/applyGuardrails
AI_GUARD_APP_NAME=ai-guard-s3-monitor

LOG_BUCKET_NAME=your-log-bucket-name
NOTIFICATION_EMAIL=security-team@example.com
SES_SENDER_EMAIL=your-verified-ses-sender@example.com

# AWS region (used by SES client)
AWS_REGION=us-east-1
